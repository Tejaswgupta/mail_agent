# ── Database ──────────────────────────────────────────────────────────────────
# Path to the SQLite database file (created automatically on first run)
DB_PATH=mail_agent.db

# ── Telegram notifications (optional) ────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Zoho Mail ─────────────────────────────────────────────────────────────────
ZOHO_MAIL_URL=https://mail.zoho.in

# ── Polling ───────────────────────────────────────────────────────────────────
POLL_INTERVAL_SECONDS=60
