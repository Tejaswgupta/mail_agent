VOTUM_SUPABASE_URL=
VOTUM_SUPABASE_KEY=
VOTUM_API_ACCESS_TOKEN=
# Filled automatically by the first-run login wizard:
VOTUM_USER_ID=
VOTUM_WORKSPACE_ID=
